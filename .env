# ─────────────────────────────────────────────────────────────────────────────
# .env.example — Copy to .env and fill in your real values
# NEVER commit .env to source control
# ─────────────────────────────────────────────────────────────────────────────

# ── GENERAL ──────────────────────────────────────────────────────────────────
TRADING_MODE=paper                   # paper | live
LOG_LEVEL=INFO                       # DEBUG | INFO | WARNING | ERROR
DB_URL=sqlite:///trading_bot.db      # SQLite default; replace with PostgreSQL for prod
STRATEGY_PRESET=balanced             # balanced | momentum | value | sentiment_driven | technical_only

# ── BINANCE (Crypto) ─────────────────────────────────────────────────────────
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_SECRET_KEY=your_binance_secret_key_here
BINANCE_TESTNET=true                 # true for paper trading

# ── COINGECKO ────────────────────────────────────────────────────────────────
COINGECKO_API_KEY=CG-sJthPcF4n9ZgLXPi8rpa5Y6U  # optional; free tier works without key

# ── GLASSNODE (On-chain) ─────────────────────────────────────────────────────
